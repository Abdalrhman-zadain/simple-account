generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

generator erd {
  provider = "prisma-erd-generator"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
}

enum PeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum BankCashTransactionKind {
  RECEIPT
  PAYMENT
  TRANSFER
}

enum BankCashTransactionStatus {
  DRAFT
  POSTED
}

enum BankReconciliationStatus {
  DRAFT
  COMPLETED
}

enum BankStatementLineStatus {
  UNMATCHED
  MATCHED
  RECONCILED
}

enum QuotationStatus {
  DRAFT
  APPROVED
  EXPIRED
  CONVERTED
  CANCELLED
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_INVOICED
  FULLY_INVOICED
  CANCELLED
}

enum SalesInvoiceStatus {
  DRAFT
  POSTED
  PARTIALLY_PAID
  FULLY_PAID
  OVERDUE
  CANCELLED
}

enum CreditNoteStatus {
  DRAFT
  POSTED
  APPLIED
  CANCELLED
}

enum AllocationStatus {
  UNALLOCATED
  PARTIAL
  FULLY_ALLOCATED
}

enum SalesRepStatus {
  ACTIVE
  INACTIVE
}

enum PurchaseRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CLOSED
}

enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
  CLOSED
}

enum PurchaseInvoiceStatus {
  DRAFT
  POSTED
  PARTIALLY_PAID
  FULLY_PAID
  CANCELLED
  REVERSED
}

enum PurchaseReceiptStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum InventoryReceiptStatus {
  DRAFT
  POSTED
  CANCELLED
  REVERSED
}

enum InventoryIssueStatus {
  DRAFT
  POSTED
  CANCELLED
  REVERSED
}

enum InventoryTransferStatus {
  DRAFT
  POSTED
  CANCELLED
  REVERSED
}

enum InventoryAdjustmentStatus {
  DRAFT
  POSTED
  CANCELLED
  REVERSED
}

enum SupplierPaymentStatus {
  DRAFT
  POSTED
  CANCELLED
  REVERSED
}

enum DebitNoteStatus {
  DRAFT
  POSTED
  APPLIED
  CANCELLED
  REVERSED
}

enum InventoryItemType {
  RAW_MATERIAL
  FINISHED_GOOD
  SERVICE
  MANUFACTURED_ITEM
}

enum InventoryCostingMethod {
  WEIGHTED_AVERAGE
  FIFO
}

enum InventoryStockMovementType {
  GOODS_RECEIPT
  GOODS_ISSUE
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum EmployeePaymentMethod {
  BANK
  CASH
  OTHER
}

enum PayrollComponentType {
  EARNING
  DEDUCTION
  EMPLOYER_CONTRIBUTION
  BENEFIT
}

enum PayrollCalculationMethod {
  FIXED_AMOUNT
  PERCENTAGE
  QUANTITY
  FORMULA
}

enum PayrollPeriodStatus {
  DRAFT
  POSTED
  CLOSED
  REVERSED
}

enum PayslipStatus {
  DRAFT
  POSTED
  PARTIALLY_PAID
  PAID
  CANCELLED
  REVERSED
}

enum PayrollPaymentStatus {
  DRAFT
  POSTED
  CANCELLED
  REVERSED
}

enum PayrollRuleType {
  TAX
  INSURANCE
  LOAN
  STATUTORY_DEDUCTION
  OTHER
}

enum PayrollAdjustmentType {
  ADJUSTMENT
  REVERSAL
}

enum TaxType {
  SALES
  PURCHASE
  ZERO_RATED
  EXEMPT
  OUT_OF_SCOPE
}

enum FixedAssetStatus {
  ACTIVE
  INACTIVE
  DISPOSED
  RETIRED
}

enum FixedAssetDepreciationMethod {
  STRAIGHT_LINE
  DECLINING_BALANCE
}

enum FixedAssetTransactionStatus {
  DRAFT
  POSTED
  CANCELLED
  REVERSED
}

enum FixedAssetDisposalMethod {
  SALE
  WRITE_OFF
  SCRAP
  OTHER
}

enum DueDateCalculationMethod {
  IMMEDIATE
  DAYS_AFTER
  END_OF_MONTH
  MANUAL
}

model Account {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  nameAr      String? // Arabic name
  description String?
  type        AccountType
  subtype     String? // e.g. Bank, Cash, Receivable, Payable
  isPosting   Boolean     @default(true)

  // Enterprise Segments (Relational)
  segment1ValueId String?
  segment1Value   SegmentValue? @relation("Segment1", fields: [segment1ValueId], references: [id])
  segment2ValueId String?
  segment2Value   SegmentValue? @relation("Segment2", fields: [segment2ValueId], references: [id])
  segment3ValueId String?
  segment3Value   SegmentValue? @relation("Segment3", fields: [segment3ValueId], references: [id])
  segment4ValueId String?
  segment4Value   SegmentValue? @relation("Segment4", fields: [segment4ValueId], references: [id])
  segment5ValueId String?
  segment5Value   SegmentValue? @relation("Segment5", fields: [segment5ValueId], references: [id])

  // Legacy/String Segments (for quick reference)
  segment1 String? // Company
  segment2 String? // Natural Account
  segment3 String? // Department
  segment4 String? // Branch
  segment5 String? // Project

  currencyCode                              String                  @default("JOD")
  isActive                                  Boolean                 @default(true)
  allowManualPosting                        Boolean                 @default(true)
  currentBalance                            Decimal                 @default(0) @db.Decimal(18, 2)
  parentAccountId                           String?
  parentAccount                             Account?                @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  childAccounts                             Account[]               @relation("AccountHierarchy")
  journalLines                              JournalEntryLine[]
  ledgerLines                               LedgerTransaction[]
  bankCashAccount                           BankCashAccount?
  bankCashCounterpartTransactions           BankCashTransaction[]   @relation("BankCashCounterAccount")
  customerReceivables                       Customer[]              @relation("CustomerReceivableAccount")
  supplierPayables                          Supplier[]              @relation("SupplierPayableAccount")
  salesRepEmployeeReceivableAccounts        SalesRepresentative[]   @relation("SalesRepEmployeeReceivableAccount")
  purchaseRequestExpenseLines               PurchaseRequestLine[]   @relation("PurchaseRequestExpenseAccount")
  purchaseInvoiceAccountLines               PurchaseInvoiceLine[]   @relation("PurchaseInvoiceClassificationAccount")
  debitNoteDiscountLines                    DebitNoteLine[]         @relation("DebitNoteDiscountAccount")
  salesQuotationRevenueLines                SalesQuotationLine[]    @relation("SalesQuotationRevenueAccount")
  salesOrderRevenueLines                    SalesOrderLine[]        @relation("SalesOrderRevenueAccount")
  salesInvoiceRevenueLines                  SalesInvoiceLine[]      @relation("SalesInvoiceRevenueAccount")
  creditNoteRevenueLines                    CreditNoteLine[]        @relation("CreditNoteRevenueAccount")
  inventoryDefaultItems                     InventoryItem[]         @relation("InventoryItemInventoryAccount")
  inventoryCogsItems                        InventoryItem[]         @relation("InventoryItemCogsAccount")
  inventorySalesItems                       InventoryItem[]         @relation("InventoryItemSalesAccount")
  inventorySalesReturnItems                 InventoryItem[]         @relation("InventoryItemSalesReturnAccount")
  inventoryAdjustmentItems                  InventoryItem[]         @relation("InventoryItemAdjustmentAccount")
  inventoryGroupDefaultInventoryAccounts    InventoryItemGroup[]    @relation("InventoryItemGroupInventoryAccount")
  inventoryGroupDefaultCogsAccounts         InventoryItemGroup[]    @relation("InventoryItemGroupCogsAccount")
  inventoryGroupDefaultSalesAccounts        InventoryItemGroup[]    @relation("InventoryItemGroupSalesAccount")
  inventoryGroupDefaultAdjustmentAccounts   InventoryItemGroup[]    @relation("InventoryItemGroupAdjustmentAccount")
  payrollExpenseComponents                  PayrollComponent[]      @relation("PayrollComponentExpenseAccount")
  payrollLiabilityComponents                PayrollComponent[]      @relation("PayrollComponentLiabilityAccount")
  payrollPeriodPayables                     PayrollPeriod[]         @relation("PayrollPeriodPayableAccount")
  fixedAssetCategoryAssetAccounts           FixedAssetCategory[]    @relation("FixedAssetCategoryAssetAccount")
  fixedAssetCategoryAccumAccounts           FixedAssetCategory[]    @relation("FixedAssetCategoryAccumulatedDepreciationAccount")
  fixedAssetCategoryExpenseAccounts         FixedAssetCategory[]    @relation("FixedAssetCategoryDepreciationExpenseAccount")
  fixedAssetCategoryGainAccounts            FixedAssetCategory[]    @relation("FixedAssetCategoryDisposalGainAccount")
  fixedAssetCategoryLossAccounts            FixedAssetCategory[]    @relation("FixedAssetCategoryDisposalLossAccount")
  fixedAssetAcquisitionClearingAccounts     FixedAssetAcquisition[] @relation("FixedAssetAcquisitionClearingAccount")
  fixedAssetDisposalProceedsAccounts        FixedAssetDisposal[]    @relation("FixedAssetDisposalProceedsAccount")
  fixedAssetDisposalExpenseClearingAccounts FixedAssetDisposal[]    @relation("FixedAssetDisposalExpenseClearingAccount")
  taxes                                     Tax[]                   @relation("TaxAccount")
  purchaseDiscountPolicies                  PurchasePolicy[]        @relation("PurchasePolicyDiscountAccount")

  createdById String?
  createdBy   User?   @relation("AccountCreator", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?   @relation("AccountUpdater", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, isActive])
  @@index([parentAccountId])
}

model BankCashAccount {
  id                   String                @id @default(cuid())
  type                 String
  name                 String
  bankName             String?
  accountNumber        String?
  currencyCode         String                @default("JOD")
  isActive             Boolean               @default(true)
  accountId            String                @unique
  account              Account               @relation(fields: [accountId], references: [id], onDelete: Restrict)
  transactions         BankCashTransaction[] @relation("BankCashPrimaryAccount")
  sourceTransfers      BankCashTransaction[] @relation("BankCashSourceAccount")
  destinationTransfers BankCashTransaction[] @relation("BankCashDestinationAccount")
  reconciliations      BankReconciliation[]
  supplierPayments     SupplierPayment[]
  payrollPayments      PayrollPayment[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([type, isActive])
}

model BankCashTransaction {
  id                           String                    @id @default(cuid())
  kind                         BankCashTransactionKind
  status                       BankCashTransactionStatus @default(DRAFT)
  reference                    String                    @unique
  transactionDate              DateTime
  amount                       Decimal                   @db.Decimal(18, 2)
  description                  String?
  counterpartyName             String?
  customerId                   String?
  customer                     Customer?                 @relation(fields: [customerId], references: [id], onDelete: Restrict)
  bankCashAccountId            String?
  bankCashAccount              BankCashAccount?          @relation("BankCashPrimaryAccount", fields: [bankCashAccountId], references: [id], onDelete: Restrict)
  sourceBankCashAccountId      String?
  sourceBankCashAccount        BankCashAccount?          @relation("BankCashSourceAccount", fields: [sourceBankCashAccountId], references: [id], onDelete: Restrict)
  destinationBankCashAccountId String?
  destinationBankCashAccount   BankCashAccount?          @relation("BankCashDestinationAccount", fields: [destinationBankCashAccountId], references: [id], onDelete: Restrict)
  counterAccountId             String?
  counterAccount               Account?                  @relation("BankCashCounterAccount", fields: [counterAccountId], references: [id], onDelete: Restrict)
  journalEntryId               String?                   @unique
  journalEntry                 JournalEntry?             @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  receiptAllocations           ReceiptAllocation[]       @relation("ReceiptTransactionAllocations")
  supplierPayment              SupplierPayment?
  payrollPayment               PayrollPayment?
  postedAt                     DateTime?
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt

  @@index([kind, status, transactionDate])
  @@index([bankCashAccountId])
  @@index([sourceBankCashAccountId])
  @@index([destinationBankCashAccountId])
  @@index([counterAccountId])
  @@index([customerId])
}

model BankReconciliation {
  id                     String                    @id @default(cuid())
  bankCashAccountId      String
  bankCashAccount        BankCashAccount           @relation(fields: [bankCashAccountId], references: [id], onDelete: Restrict)
  statementDate          DateTime
  statementEndingBalance Decimal                   @db.Decimal(18, 2)
  notes                  String?
  status                 BankReconciliationStatus  @default(DRAFT)
  completedAt            DateTime?
  statementLines         BankStatementLine[]
  matches                BankReconciliationMatch[]
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  @@index([bankCashAccountId, status, statementDate])
}

model BankStatementLine {
  id               String                    @id @default(cuid())
  reconciliationId String
  reconciliation   BankReconciliation        @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
  transactionDate  DateTime
  reference        String?
  description      String?
  debitAmount      Decimal                   @default(0) @db.Decimal(18, 2)
  creditAmount     Decimal                   @default(0) @db.Decimal(18, 2)
  status           BankStatementLineStatus   @default(UNMATCHED)
  matches          BankReconciliationMatch[]
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([reconciliationId, status, transactionDate])
}

model BankReconciliationMatch {
  id                  String             @id @default(cuid())
  reconciliationId    String
  reconciliation      BankReconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
  statementLineId     String
  statementLine       BankStatementLine  @relation(fields: [statementLineId], references: [id], onDelete: Cascade)
  ledgerTransactionId String
  ledgerTransaction   LedgerTransaction  @relation(fields: [ledgerTransactionId], references: [id], onDelete: Restrict)
  isReconciled        Boolean            @default(false)
  matchedAt           DateTime           @default(now())
  reconciledAt        DateTime?

  @@unique([statementLineId, ledgerTransactionId])
  @@index([reconciliationId])
  @@index([ledgerTransactionId])
}

model AccountSubtype {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model PaymentMethodType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model Tax {
  id                   String                @id @default(cuid())
  taxCode              String                @unique
  taxName              String
  rate                 Decimal               @db.Decimal(5, 2)
  taxType              TaxType
  taxAccountId         String?
  taxAccount           Account?              @relation("TaxAccount", fields: [taxAccountId], references: [id], onDelete: Restrict)
  isActive             Boolean               @default(true)
  defaultForTreatments TaxTreatment[]        @relation("TaxTreatmentDefaultTax")
  purchaseOrderLines   PurchaseOrderLine[]
  purchaseInvoiceLines PurchaseInvoiceLine[]
  debitNoteLines       DebitNoteLine[]
  salesQuotationLines  SalesQuotationLine[]
  salesOrderLines      SalesOrderLine[]
  salesInvoiceLines    SalesInvoiceLine[]
  creditNoteLines      CreditNoteLine[]
  inventoryItems       InventoryItem[]       @relation("InventoryItemDefaultTax")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([isActive])
  @@index([taxType])
  @@index([taxAccountId])
}

model TaxTreatment {
  id           String     @id @default(cuid())
  code         String     @unique
  arabicName   String
  englishName  String
  description  String?
  defaultTaxId String?
  defaultTax   Tax?       @relation("TaxTreatmentDefaultTax", fields: [defaultTaxId], references: [id], onDelete: Restrict)
  isActive     Boolean    @default(true)
  customers    Customer[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([isActive, code])
  @@index([defaultTaxId])
}

model JournalEntryType {
  id        String         @id @default(cuid())
  name      String         @unique
  isActive  Boolean        @default(true)
  entries   JournalEntry[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([isActive])
}

model JournalEntry {
  id          String             @id @default(cuid())
  reference   String             @unique
  description String?
  entryDate   DateTime
  status      JournalEntryStatus @default(DRAFT)
  postedAt    DateTime?

  journalEntryTypeId String?
  journalEntryType   JournalEntryType? @relation(fields: [journalEntryTypeId], references: [id])

  fiscalPeriodId String?
  fiscalPeriod   FiscalPeriod? @relation(fields: [fiscalPeriodId], references: [id])

  reversalOfId              String?                    @unique
  reversalOf                JournalEntry?              @relation("JournalEntryReversal", fields: [reversalOfId], references: [id])
  reversedBy                JournalEntry?              @relation("JournalEntryReversal")
  lines                     JournalEntryLine[]
  ledgerLines               LedgerTransaction[]
  postingBatchId            String?                    @unique
  postingBatch              PostingBatch?              @relation(fields: [postingBatchId], references: [id])
  bankCashTransaction       BankCashTransaction?
  salesInvoice              SalesInvoice?              @relation("SalesInvoiceToJournalEntry")
  purchaseInvoice           PurchaseInvoice?           @relation("PurchaseInvoiceToJournalEntry")
  creditNote                CreditNote?                @relation("CreditNoteToJournalEntry")
  debitNote                 DebitNote?                 @relation("DebitNoteToJournalEntry")
  inventoryGoodsReceipt     InventoryGoodsReceipt?     @relation("InventoryGoodsReceiptToJournalEntry")
  inventoryGoodsIssue       InventoryGoodsIssue?       @relation("InventoryGoodsIssueToJournalEntry")
  inventoryAdjustment       InventoryAdjustment?       @relation("InventoryAdjustmentToJournalEntry")
  payrollPeriod             PayrollPeriod?             @relation("PayrollPeriodToJournalEntry")
  payrollAdjustment         PayrollAdjustment?         @relation("PayrollAdjustmentToJournalEntry")
  fixedAssetAcquisition     FixedAssetAcquisition?     @relation("FixedAssetAcquisitionToJournalEntry")
  fixedAssetDepreciationRun FixedAssetDepreciationRun? @relation("FixedAssetDepreciationRunToJournalEntry")
  fixedAssetDisposal        FixedAssetDisposal?        @relation("FixedAssetDisposalToJournalEntry")

  sourceType   String?
  sourceId     String?
  sourceNumber String?
  customerId   String?
  customer     Customer? @relation("CustomerToJournalEntry", fields: [customerId], references: [id])
  currencyCode String?   @db.VarChar(12)

  createdById String?
  createdBy   User?   @relation("JournalCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, entryDate])
  @@index([fiscalPeriodId])
  @@index([journalEntryTypeId])
  @@index([sourceType, sourceId])
  @@index([customerId])
  }

  model Customer {
  id                   String                @id @default(cuid())
  code                 String                @unique
  name                 String
  contactInfo          String?
  taxInfo              String?
  taxTreatmentId       String
  taxTreatment         TaxTreatment          @relation(fields: [taxTreatmentId], references: [id], onDelete: Restrict)
  salesRepresentative  String?
  salesRepId           String?
  salesRep             SalesRepresentative?  @relation(fields: [salesRepId], references: [id], onDelete: SetNull)
  paymentTerms         String?
  creditLimit          Decimal               @default(0) @db.Decimal(18, 2)
  currentBalance       Decimal               @default(0) @db.Decimal(18, 2)
  isActive             Boolean               @default(true)
  receivableAccountId  String
  receivableAccount    Account               @relation("CustomerReceivableAccount", fields: [receivableAccountId], references: [id], onDelete: Restrict)
  quotations           SalesQuotation[]
  salesOrders          SalesOrder[]
  invoices             SalesInvoice[]
  creditNotes          CreditNote[]
  bankCashTransactions BankCashTransaction[]
  journalEntries       JournalEntry[]        @relation("CustomerToJournalEntry")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt


  @@index([isActive, name])
  @@index([salesRepId])
  @@index([taxTreatmentId])
}

model SalesRepresentative {
  id                          String         @id @default(cuid())
  code                        String         @unique
  name                        String
  phone                       String?
  email                       String?
  defaultCommissionRate       Decimal        @default(0) @db.Decimal(5, 2)
  employeeReceivableAccountId String?
  employeeReceivableAccount   Account?       @relation("SalesRepEmployeeReceivableAccount", fields: [employeeReceivableAccountId], references: [id], onDelete: Restrict)
  status                      SalesRepStatus @default(ACTIVE)
  customers                   Customer[]
  createdAt                   DateTime       @default(now())
  updatedAt                   DateTime       @updatedAt

  @@index([status, name])
  @@index([employeeReceivableAccountId])
}

model PaymentTerm {
  id                String                   @id @default(cuid())
  name              String                   @unique
  nameAr            String?
  calculationMethod DueDateCalculationMethod @default(DAYS_AFTER)
  numberOfDays      Int?
  isActive          Boolean                  @default(true)
  suppliers         Supplier[]
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  @@index([isActive, name])
}

model Supplier {
  id               String            @id @default(cuid())
  code             String            @unique
  name             String
  contactInfo      String?
  phone            String?
  email            String?
  address          String?
  paymentTerms     String? // Deprecated - use paymentTermId
  paymentTermId    String?
  paymentTerm      PaymentTerm?      @relation(fields: [paymentTermId], references: [id], onDelete: SetNull)
  taxInfo          String?
  defaultCurrency  String            @default("JOD")
  currentBalance   Decimal           @default(0) @db.Decimal(18, 2)
  isActive         Boolean           @default(true)
  payableAccountId String
  payableAccount   Account           @relation("SupplierPayableAccount", fields: [payableAccountId], references: [id], onDelete: Restrict)
  purchaseOrders   PurchaseOrder[]
  purchaseReceipts PurchaseReceipt[]
  purchaseInvoices PurchaseInvoice[]
  supplierPayments SupplierPayment[]
  debitNotes       DebitNote[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([isActive, name])
}

model InventoryItem {
  id                     String                        @id @default(cuid())
  code                   String                        @unique
  name                   String
  description            String?
  internalNotes          String?                       @db.Text
  itemImageUrl           String?
  attachmentsText        String?                       @db.Text
  barcode                String?                       @unique
  qrCodeValue            String?                       @db.Text
  unitOfMeasure          String
  unitOfMeasureId        String?
  unitOfMeasureRef       InventoryUnitOfMeasure?       @relation(fields: [unitOfMeasureId], references: [id], onDelete: Restrict)
  category               String?
  itemGroupId            String?
  itemGroup              InventoryItemGroup?           @relation(fields: [itemGroupId], references: [id], onDelete: Restrict)
  itemCategoryId         String?
  itemCategory           InventoryItemCategory?        @relation(fields: [itemCategoryId], references: [id], onDelete: Restrict)
  type                   InventoryItemType             @default(FINISHED_GOOD)
  inventoryAccountId     String?
  inventoryAccount       Account?                      @relation("InventoryItemInventoryAccount", fields: [inventoryAccountId], references: [id], onDelete: Restrict)
  cogsAccountId          String?
  cogsAccount            Account?                      @relation("InventoryItemCogsAccount", fields: [cogsAccountId], references: [id], onDelete: Restrict)
  salesAccountId         String?
  salesAccount           Account?                      @relation("InventoryItemSalesAccount", fields: [salesAccountId], references: [id], onDelete: Restrict)
  salesReturnAccountId   String?
  salesReturnAccount     Account?                      @relation("InventoryItemSalesReturnAccount", fields: [salesReturnAccountId], references: [id], onDelete: Restrict)
  adjustmentAccountId    String?
  adjustmentAccount      Account?                      @relation("InventoryItemAdjustmentAccount", fields: [adjustmentAccountId], references: [id], onDelete: Restrict)
  defaultSalesPrice      Decimal?                      @db.Decimal(18, 4)
  defaultPurchasePrice   Decimal?                      @db.Decimal(18, 4)
  currencyCode           String?                       @db.VarChar(12)
  taxable                Boolean                       @default(false)
  defaultTaxId           String?
  defaultTax             Tax?                          @relation("InventoryItemDefaultTax", fields: [defaultTaxId], references: [id], onDelete: Restrict)
  trackInventory         Boolean                       @default(true)
  reorderLevel           Decimal                       @default(0) @db.Decimal(18, 4)
  reorderQuantity        Decimal                       @default(0) @db.Decimal(18, 4)
  preferredWarehouseId   String?
  preferredWarehouse     InventoryWarehouse?           @relation("InventoryItemPreferredWarehouse", fields: [preferredWarehouseId], references: [id], onDelete: Restrict)
  preferredWarehouseCode String?
  isActive               Boolean                       @default(true)
  onHandQuantity         Decimal                       @default(0) @db.Decimal(18, 4)
  valuationAmount        Decimal                       @default(0) @db.Decimal(18, 2)
  goodsReceiptLines      InventoryGoodsReceiptLine[]
  goodsIssueLines        InventoryGoodsIssueLine[]
  transferLines          InventoryTransferLine[]
  adjustmentLines        InventoryAdjustmentLine[]
  salesQuotationLines    SalesQuotationLine[]
  salesOrderLines        SalesOrderLine[]
  salesInvoiceLines      SalesInvoiceLine[]
  purchaseRequestLines   PurchaseRequestLine[]         @relation("PurchaseRequestLineInventoryItem")
  purchaseOrderLines     PurchaseOrderLine[]           @relation("PurchaseOrderLineInventoryItem")
  purchaseInvoiceLines   PurchaseInvoiceLine[]
  unitConversions        InventoryItemUnitConversion[]
  warehouseBalances      InventoryWarehouseBalance[]
  costLayers             InventoryCostLayer[]
  stockMovements         InventoryStockMovement[]
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt

  @@index([type, isActive])
  @@index([name])
  @@index([itemGroupId, itemCategoryId])
  @@index([unitOfMeasureId])
  @@index([barcode])
  @@index([preferredWarehouseId])
  @@index([defaultTaxId])
  @@index([salesReturnAccountId])
}

model InventoryItemGroup {
  id                  String                  @id @default(cuid())
  code                String                  @unique
  name                String
  description         String?
  parentGroupId       String?
  parentGroup         InventoryItemGroup?     @relation("InventoryItemGroupHierarchy", fields: [parentGroupId], references: [id], onDelete: Restrict)
