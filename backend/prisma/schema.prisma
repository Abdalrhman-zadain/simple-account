generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

generator erd {
  provider = "prisma-erd-generator"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum JournalEntryStatus {
  DRAFT
  POSTED
}

enum PeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum BankCashTransactionKind {
  RECEIPT
  PAYMENT
  TRANSFER
}

enum BankCashTransactionStatus {
  DRAFT
  POSTED
}

enum BankReconciliationStatus {
  DRAFT
  COMPLETED
}

enum BankStatementLineStatus {
  UNMATCHED
  MATCHED
  RECONCILED
}

enum QuotationStatus {
  DRAFT
  APPROVED
  EXPIRED
  CONVERTED
  CANCELLED
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_INVOICED
  FULLY_INVOICED
  CANCELLED
}

enum SalesInvoiceStatus {
  DRAFT
  POSTED
  PARTIALLY_PAID
  FULLY_PAID
  OVERDUE
  CANCELLED
}

enum CreditNoteStatus {
  DRAFT
  POSTED
  APPLIED
  CANCELLED
}

enum AllocationStatus {
  UNALLOCATED
  PARTIAL
  FULLY_ALLOCATED
}

enum PurchaseRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  CLOSED
}

enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
  CLOSED
}

enum PurchaseInvoiceStatus {
  DRAFT
  POSTED
  PARTIALLY_PAID
  FULLY_PAID
  CANCELLED
}

enum SupplierPaymentStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum DebitNoteStatus {
  DRAFT
  POSTED
  APPLIED
  CANCELLED
}

model Account {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  nameAr      String? // Arabic name
  description String?
  type        AccountType
  subtype     String? // e.g. Bank, Cash, Receivable, Payable
  isPosting   Boolean     @default(true)

  // Enterprise Segments (Relational)
  segment1ValueId String?
  segment1Value   SegmentValue? @relation("Segment1", fields: [segment1ValueId], references: [id])
  segment2ValueId String?
  segment2Value   SegmentValue? @relation("Segment2", fields: [segment2ValueId], references: [id])
  segment3ValueId String?
  segment3Value   SegmentValue? @relation("Segment3", fields: [segment3ValueId], references: [id])
  segment4ValueId String?
  segment4Value   SegmentValue? @relation("Segment4", fields: [segment4ValueId], references: [id])
  segment5ValueId String?
  segment5Value   SegmentValue? @relation("Segment5", fields: [segment5ValueId], references: [id])

  // Legacy/String Segments (for quick reference)
  segment1 String? // Company
  segment2 String? // Natural Account
  segment3 String? // Department
  segment4 String? // Branch
  segment5 String? // Project

  currencyCode                    String                @default("JOD")
  isActive                        Boolean               @default(true)
  allowManualPosting              Boolean               @default(true)
  currentBalance                  Decimal               @default(0) @db.Decimal(18, 2)
  parentAccountId                 String?
  parentAccount                   Account?              @relation("AccountHierarchy", fields: [parentAccountId], references: [id])
  childAccounts                   Account[]             @relation("AccountHierarchy")
  journalLines                    JournalEntryLine[]
  ledgerLines                     LedgerTransaction[]
  bankCashAccount                 BankCashAccount?
  bankCashCounterpartTransactions BankCashTransaction[] @relation("BankCashCounterAccount")
  customerReceivables             Customer[]            @relation("CustomerReceivableAccount")
  supplierPayables               Supplier[]            @relation("SupplierPayableAccount")
  purchaseRequestExpenseLines     PurchaseRequestLine[] @relation("PurchaseRequestExpenseAccount")
  purchaseInvoiceAccountLines     PurchaseInvoiceLine[] @relation("PurchaseInvoiceClassificationAccount")
  salesQuotationRevenueLines      SalesQuotationLine[]  @relation("SalesQuotationRevenueAccount")
  salesOrderRevenueLines          SalesOrderLine[]      @relation("SalesOrderRevenueAccount")
  salesInvoiceRevenueLines        SalesInvoiceLine[]    @relation("SalesInvoiceRevenueAccount")
  creditNoteRevenueLines          CreditNoteLine[]      @relation("CreditNoteRevenueAccount")

  createdById String?
  createdBy   User?   @relation("AccountCreator", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?   @relation("AccountUpdater", fields: [updatedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, isActive])
  @@index([parentAccountId])
}

model BankCashAccount {
  id                   String                @id @default(cuid())
  type                 String
  name                 String
  bankName             String?
  accountNumber        String?
  currencyCode         String                @default("JOD")
  isActive             Boolean               @default(true)
  accountId            String                @unique
  account              Account               @relation(fields: [accountId], references: [id], onDelete: Restrict)
  transactions         BankCashTransaction[] @relation("BankCashPrimaryAccount")
  sourceTransfers      BankCashTransaction[] @relation("BankCashSourceAccount")
  destinationTransfers BankCashTransaction[] @relation("BankCashDestinationAccount")
  reconciliations      BankReconciliation[]
  supplierPayments     SupplierPayment[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([type, isActive])
}

model BankCashTransaction {
  id                           String                    @id @default(cuid())
  kind                         BankCashTransactionKind
  status                       BankCashTransactionStatus @default(DRAFT)
  reference                    String                    @unique
  transactionDate              DateTime
  amount                       Decimal                   @db.Decimal(18, 2)
  description                  String?
  counterpartyName             String?
  customerId                   String?
  customer                     Customer?                 @relation(fields: [customerId], references: [id], onDelete: Restrict)
  bankCashAccountId            String?
  bankCashAccount              BankCashAccount?          @relation("BankCashPrimaryAccount", fields: [bankCashAccountId], references: [id], onDelete: Restrict)
  sourceBankCashAccountId      String?
  sourceBankCashAccount        BankCashAccount?          @relation("BankCashSourceAccount", fields: [sourceBankCashAccountId], references: [id], onDelete: Restrict)
  destinationBankCashAccountId String?
  destinationBankCashAccount   BankCashAccount?          @relation("BankCashDestinationAccount", fields: [destinationBankCashAccountId], references: [id], onDelete: Restrict)
  counterAccountId             String?
  counterAccount               Account?                  @relation("BankCashCounterAccount", fields: [counterAccountId], references: [id], onDelete: Restrict)
  journalEntryId               String?                   @unique
  journalEntry                 JournalEntry?             @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  receiptAllocations           ReceiptAllocation[]       @relation("ReceiptTransactionAllocations")
  supplierPayment              SupplierPayment?
  postedAt                     DateTime?
  createdAt                    DateTime                  @default(now())
  updatedAt                    DateTime                  @updatedAt

  @@index([kind, status, transactionDate])
  @@index([bankCashAccountId])
  @@index([sourceBankCashAccountId])
  @@index([destinationBankCashAccountId])
  @@index([counterAccountId])
  @@index([customerId])
}

model BankReconciliation {
  id                     String                    @id @default(cuid())
  bankCashAccountId      String
  bankCashAccount        BankCashAccount           @relation(fields: [bankCashAccountId], references: [id], onDelete: Restrict)
  statementDate          DateTime
  statementEndingBalance Decimal                   @db.Decimal(18, 2)
  notes                  String?
  status                 BankReconciliationStatus  @default(DRAFT)
  completedAt            DateTime?
  statementLines         BankStatementLine[]
  matches                BankReconciliationMatch[]
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  @@index([bankCashAccountId, status, statementDate])
}

model BankStatementLine {
  id               String                    @id @default(cuid())
  reconciliationId String
  reconciliation   BankReconciliation        @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
  transactionDate  DateTime
  reference        String?
  description      String?
  debitAmount      Decimal                   @default(0) @db.Decimal(18, 2)
  creditAmount     Decimal                   @default(0) @db.Decimal(18, 2)
  status           BankStatementLineStatus   @default(UNMATCHED)
  matches          BankReconciliationMatch[]
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt

  @@index([reconciliationId, status, transactionDate])
}

model BankReconciliationMatch {
  id                  String             @id @default(cuid())
  reconciliationId    String
  reconciliation      BankReconciliation @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)
  statementLineId     String
  statementLine       BankStatementLine  @relation(fields: [statementLineId], references: [id], onDelete: Cascade)
  ledgerTransactionId String
  ledgerTransaction   LedgerTransaction  @relation(fields: [ledgerTransactionId], references: [id], onDelete: Restrict)
  isReconciled        Boolean            @default(false)
  matchedAt           DateTime           @default(now())
  reconciledAt        DateTime?

  @@unique([statementLineId, ledgerTransactionId])
  @@index([reconciliationId])
  @@index([ledgerTransactionId])
}

model AccountSubtype {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model PaymentMethodType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model JournalEntryType {
  id        String         @id @default(cuid())
  name      String         @unique
  isActive  Boolean        @default(true)
  entries   JournalEntry[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([isActive])
}

model JournalEntry {
  id          String             @id @default(cuid())
  reference   String             @unique
  description String?
  entryDate   DateTime
  status      JournalEntryStatus @default(DRAFT)
  postedAt    DateTime?

  journalEntryTypeId String?
  journalEntryType   JournalEntryType? @relation(fields: [journalEntryTypeId], references: [id])

  fiscalPeriodId String?
  fiscalPeriod   FiscalPeriod? @relation(fields: [fiscalPeriodId], references: [id])

  reversalOfId        String?              @unique
  reversalOf          JournalEntry?        @relation("JournalEntryReversal", fields: [reversalOfId], references: [id])
  reversedBy          JournalEntry?        @relation("JournalEntryReversal")
  lines               JournalEntryLine[]
  ledgerLines         LedgerTransaction[]
  postingBatchId      String?              @unique
  postingBatch        PostingBatch?        @relation(fields: [postingBatchId], references: [id])
  bankCashTransaction BankCashTransaction?
  salesInvoice        SalesInvoice?        @relation("SalesInvoiceToJournalEntry")
  purchaseInvoice     PurchaseInvoice?     @relation("PurchaseInvoiceToJournalEntry")
  creditNote          CreditNote?          @relation("CreditNoteToJournalEntry")
  debitNote           DebitNote?           @relation("DebitNoteToJournalEntry")

  createdById String?
  createdBy   User?   @relation("JournalCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, entryDate])
  @@index([fiscalPeriodId])
  @@index([journalEntryTypeId])
}

model Customer {
  id                   String                @id @default(cuid())
  code                 String                @unique
  name                 String
  contactInfo          String?
  taxInfo              String?
  salesRepresentative  String?
  paymentTerms         String?
  creditLimit          Decimal               @default(0) @db.Decimal(18, 2)
  currentBalance       Decimal               @default(0) @db.Decimal(18, 2)
  isActive             Boolean               @default(true)
  receivableAccountId  String
  receivableAccount    Account               @relation("CustomerReceivableAccount", fields: [receivableAccountId], references: [id], onDelete: Restrict)
  quotations           SalesQuotation[]
  salesOrders          SalesOrder[]
  invoices             SalesInvoice[]
  creditNotes          CreditNote[]
  bankCashTransactions BankCashTransaction[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([isActive, name])
}

model Supplier {
  id                String   @id @default(cuid())
  code              String   @unique
  name              String
  contactInfo       String?
  paymentTerms      String?
  taxInfo           String?
  defaultCurrency   String   @default("JOD")
  currentBalance    Decimal  @default(0) @db.Decimal(18, 2)
  isActive          Boolean  @default(true)
  payableAccountId  String
  payableAccount    Account  @relation("SupplierPayableAccount", fields: [payableAccountId], references: [id], onDelete: Restrict)
  purchaseOrders    PurchaseOrder[]
  purchaseInvoices  PurchaseInvoice[]
  supplierPayments  SupplierPayment[]
  debitNotes        DebitNote[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([isActive, name])
}

model PurchaseRequest {
  id             String                       @id @default(cuid())
  reference      String                       @unique
  status         PurchaseRequestStatus        @default(DRAFT)
  requestDate    DateTime
  description    String?
  lines          PurchaseRequestLine[]
  statusHistory  PurchaseRequestStatusHistory[]
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime                     @default(now())
  updatedAt      DateTime                     @updatedAt

  @@index([status, requestDate])
}

model PurchaseRequestLine {
  id                    String           @id @default(cuid())
  purchaseRequestId     String
  purchaseRequest       PurchaseRequest  @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  lineNumber            Int
  itemName              String?
  description           String
  quantity              Decimal          @default(1) @db.Decimal(18, 4)
  requestedDeliveryDate DateTime?
  justification         String?
  expenseAccountId      String?
  expenseAccount        Account?         @relation("PurchaseRequestExpenseAccount", fields: [expenseAccountId], references: [id], onDelete: Restrict)
  createdAt             DateTime         @default(now())

  @@unique([purchaseRequestId, lineNumber])
  @@index([requestedDeliveryDate])
  @@index([expenseAccountId])
}

model PurchaseRequestStatusHistory {
  id                String                @id @default(cuid())
  purchaseRequestId String
  purchaseRequest   PurchaseRequest       @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  status            PurchaseRequestStatus
  note              String?
  changedAt         DateTime              @default(now())
  createdAt         DateTime              @default(now())

  @@index([purchaseRequestId, changedAt])
}

model PurchaseOrder {
  id                      String              @id @default(cuid())
  reference               String              @unique
  status                  PurchaseOrderStatus @default(DRAFT)
  orderDate               DateTime
  supplierId              String
  supplier                Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  currencyCode            String              @default("JOD")
  description             String?
  sourcePurchaseRequestId String?
  sourcePurchaseRequest   PurchaseRequest?    @relation(fields: [sourcePurchaseRequestId], references: [id], onDelete: Restrict)
  subtotalAmount          Decimal             @default(0) @db.Decimal(18, 2)
  taxAmount               Decimal             @default(0) @db.Decimal(18, 2)
  totalAmount             Decimal             @default(0) @db.Decimal(18, 2)
  lines                   PurchaseOrderLine[]
  purchaseInvoices        PurchaseInvoice[]
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  @@index([supplierId, status, orderDate])
  @@index([sourcePurchaseRequestId])
}

model PurchaseOrderLine {
  id                    String        @id @default(cuid())
  purchaseOrderId       String
  purchaseOrder         PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  lineNumber            Int
  itemName              String?
  description           String
  quantity              Decimal       @default(1) @db.Decimal(18, 4)
  unitPrice             Decimal       @default(0) @db.Decimal(18, 2)
  taxAmount             Decimal       @default(0) @db.Decimal(18, 2)
  lineTotalAmount       Decimal       @default(0) @db.Decimal(18, 2)
  requestedDeliveryDate DateTime?
  createdAt             DateTime      @default(now())

  @@unique([purchaseOrderId, lineNumber])
}

model PurchaseInvoice {
  id                    String                @id @default(cuid())
  reference             String                @unique
  status                PurchaseInvoiceStatus @default(DRAFT)
  invoiceDate           DateTime
  supplierId            String
  supplier              Supplier              @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  currencyCode          String                @default("JOD")
  description           String?
  sourcePurchaseOrderId String?
  sourcePurchaseOrder   PurchaseOrder?        @relation(fields: [sourcePurchaseOrderId], references: [id], onDelete: Restrict)
  subtotalAmount        Decimal               @default(0) @db.Decimal(18, 2)
  discountAmount        Decimal               @default(0) @db.Decimal(18, 2)
  taxAmount             Decimal               @default(0) @db.Decimal(18, 2)
  totalAmount           Decimal               @default(0) @db.Decimal(18, 2)
  allocatedAmount       Decimal               @default(0) @db.Decimal(18, 2)
  outstandingAmount     Decimal               @default(0) @db.Decimal(18, 2)
  allocationStatus      AllocationStatus      @default(UNALLOCATED)
  journalEntryId        String?               @unique
  journalEntry          JournalEntry?         @relation("PurchaseInvoiceToJournalEntry", fields: [journalEntryId], references: [id], onDelete: Restrict)
  lines                 PurchaseInvoiceLine[]
  supplierAllocations   SupplierPaymentAllocation[]
  debitNotes            DebitNote[]
  postedAt              DateTime?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt

  @@index([supplierId, status, invoiceDate])
  @@index([allocationStatus])
  @@index([sourcePurchaseOrderId])
}

model PurchaseInvoiceLine {
  id                 String          @id @default(cuid())
  purchaseInvoiceId  String
  purchaseInvoice    PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  lineNumber         Int
  itemName           String?
  description        String
  quantity           Decimal         @default(1) @db.Decimal(18, 4)
  unitPrice          Decimal         @default(0) @db.Decimal(18, 2)
  discountAmount     Decimal         @default(0) @db.Decimal(18, 2)
  taxAmount          Decimal         @default(0) @db.Decimal(18, 2)
  lineSubtotalAmount Decimal         @default(0) @db.Decimal(18, 2)
  lineTotalAmount    Decimal         @default(0) @db.Decimal(18, 2)
  accountId          String
  account            Account         @relation("PurchaseInvoiceClassificationAccount", fields: [accountId], references: [id], onDelete: Restrict)
  createdAt          DateTime        @default(now())

  @@unique([purchaseInvoiceId, lineNumber])
  @@index([accountId])
}

model SupplierPayment {
  id                 String                  @id @default(cuid())
  reference          String                  @unique
  status             SupplierPaymentStatus   @default(DRAFT)
  paymentDate        DateTime
  supplierId         String
  supplier           Supplier                @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  amount             Decimal                 @db.Decimal(18, 2)
  allocatedAmount    Decimal                 @default(0) @db.Decimal(18, 2)
  unappliedAmount    Decimal                 @default(0) @db.Decimal(18, 2)
  bankCashAccountId  String
  bankCashAccount    BankCashAccount         @relation(fields: [bankCashAccountId], references: [id], onDelete: Restrict)
  description        String?
  bankCashTransactionId String?              @unique
  bankCashTransaction BankCashTransaction?   @relation(fields: [bankCashTransactionId], references: [id], onDelete: Restrict)
  allocations        SupplierPaymentAllocation[]
  postedAt           DateTime?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([supplierId, status, paymentDate])
  @@index([bankCashAccountId])
}

model SupplierPaymentAllocation {
  id                String           @id @default(cuid())
  supplierPaymentId String
  supplierPayment   SupplierPayment  @relation(fields: [supplierPaymentId], references: [id], onDelete: Cascade)
  purchaseInvoiceId String
  purchaseInvoice   PurchaseInvoice  @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Restrict)
  amount            Decimal          @db.Decimal(18, 2)
  allocatedAt       DateTime         @default(now())
  createdAt         DateTime         @default(now())

  @@unique([supplierPaymentId, purchaseInvoiceId])
  @@index([purchaseInvoiceId])
}

model DebitNote {
  id                String          @id @default(cuid())
  reference         String          @unique
  status            DebitNoteStatus @default(DRAFT)
  noteDate          DateTime
  supplierId        String
  supplier          Supplier        @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  purchaseInvoiceId String?
  purchaseInvoice   PurchaseInvoice? @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Restrict)
  currencyCode      String          @default("JOD")
  description       String?
  subtotalAmount    Decimal         @default(0) @db.Decimal(18, 2)
  taxAmount         Decimal         @default(0) @db.Decimal(18, 2)
  totalAmount       Decimal         @default(0) @db.Decimal(18, 2)
  journalEntryId    String?         @unique
  journalEntry      JournalEntry?   @relation("DebitNoteToJournalEntry", fields: [journalEntryId], references: [id], onDelete: Restrict)
  lines             DebitNoteLine[]
  postedAt          DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([supplierId, status, noteDate])
  @@index([purchaseInvoiceId])
}

model DebitNoteLine {
  id              String    @id @default(cuid())
  debitNoteId     String
  debitNote       DebitNote @relation(fields: [debitNoteId], references: [id], onDelete: Cascade)
  lineNumber      Int
  quantity        Decimal   @default(1) @db.Decimal(18, 4)
  amount          Decimal   @default(0) @db.Decimal(18, 2)
  taxAmount       Decimal   @default(0) @db.Decimal(18, 2)
  reason          String
  lineTotalAmount Decimal   @default(0) @db.Decimal(18, 2)
  createdAt       DateTime  @default(now())

  @@unique([debitNoteId, lineNumber])
}

model SalesQuotation {
  id             String               @id @default(cuid())
  reference      String               @unique
  status         QuotationStatus      @default(DRAFT)
  quotationDate  DateTime
  validityDate   DateTime
  customerId     String
  customer       Customer             @relation(fields: [customerId], references: [id], onDelete: Restrict)
  currencyCode   String               @default("JOD")
  description    String?
  subtotalAmount Decimal              @default(0) @db.Decimal(18, 2)
  discountAmount Decimal              @default(0) @db.Decimal(18, 2)
  taxAmount      Decimal              @default(0) @db.Decimal(18, 2)
  totalAmount    Decimal              @default(0) @db.Decimal(18, 2)
  lines          SalesQuotationLine[]
  salesOrders    SalesOrder[]
  salesInvoices  SalesInvoice[]       @relation("InvoiceSourceQuotation")
  convertedAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([customerId, status, quotationDate])
}

model SalesQuotationLine {
  id                 String         @id @default(cuid())
  salesQuotationId   String
  salesQuotation     SalesQuotation @relation(fields: [salesQuotationId], references: [id], onDelete: Cascade)
  lineNumber         Int
  itemName           String?
  description        String?
  quantity           Decimal        @default(1) @db.Decimal(18, 4)
  unitPrice          Decimal        @db.Decimal(18, 2)
  discountAmount     Decimal        @default(0) @db.Decimal(18, 2)
  taxAmount          Decimal        @default(0) @db.Decimal(18, 2)
  lineSubtotalAmount Decimal        @db.Decimal(18, 2)
  lineTotalAmount    Decimal        @db.Decimal(18, 2)
  revenueAccountId   String?
  revenueAccount     Account?       @relation("SalesQuotationRevenueAccount", fields: [revenueAccountId], references: [id], onDelete: Restrict)
  createdAt          DateTime       @default(now())

  @@unique([salesQuotationId, lineNumber])
  @@index([revenueAccountId])
}

model SalesOrder {
  id                String           @id @default(cuid())
  reference         String           @unique
  status            SalesOrderStatus @default(DRAFT)
  orderDate         DateTime
  promisedDate      DateTime?
  customerId        String
  customer          Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  currencyCode      String           @default("JOD")
  shippingDetails   String?
  description       String?
  sourceQuotationId String?
  sourceQuotation   SalesQuotation?  @relation(fields: [sourceQuotationId], references: [id], onDelete: Restrict)
  subtotalAmount    Decimal          @default(0) @db.Decimal(18, 2)
  discountAmount    Decimal          @default(0) @db.Decimal(18, 2)
  taxAmount         Decimal          @default(0) @db.Decimal(18, 2)
  totalAmount       Decimal          @default(0) @db.Decimal(18, 2)
  lines             SalesOrderLine[]
  salesInvoices     SalesInvoice[]   @relation("InvoiceSourceSalesOrder")
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([customerId, status, orderDate])
  @@index([sourceQuotationId])
}

model SalesOrderLine {
  id                 String     @id @default(cuid())
  salesOrderId       String
  salesOrder         SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  lineNumber         Int
  itemName           String?
  description        String?
  quantity           Decimal    @default(1) @db.Decimal(18, 4)
  unitPrice          Decimal    @db.Decimal(18, 2)
  discountAmount     Decimal    @default(0) @db.Decimal(18, 2)
  taxAmount          Decimal    @default(0) @db.Decimal(18, 2)
  lineSubtotalAmount Decimal    @db.Decimal(18, 2)
  lineTotalAmount    Decimal    @db.Decimal(18, 2)
  revenueAccountId   String?
  revenueAccount     Account?   @relation("SalesOrderRevenueAccount", fields: [revenueAccountId], references: [id], onDelete: Restrict)
  createdAt          DateTime   @default(now())

  @@unique([salesOrderId, lineNumber])
  @@index([revenueAccountId])
}

model SalesInvoice {
  id                 String              @id @default(cuid())
  reference          String              @unique
  status             SalesInvoiceStatus  @default(DRAFT)
  invoiceDate        DateTime
  dueDate            DateTime?
  customerId         String
  customer           Customer            @relation(fields: [customerId], references: [id], onDelete: Restrict)
  currencyCode       String              @default("JOD")
  description        String?
  sourceQuotationId  String?
  sourceQuotation    SalesQuotation?     @relation("InvoiceSourceQuotation", fields: [sourceQuotationId], references: [id], onDelete: Restrict)
  sourceSalesOrderId String?
  sourceSalesOrder   SalesOrder?         @relation("InvoiceSourceSalesOrder", fields: [sourceSalesOrderId], references: [id], onDelete: Restrict)
  subtotalAmount     Decimal             @default(0) @db.Decimal(18, 2)
  discountAmount     Decimal             @default(0) @db.Decimal(18, 2)
  taxAmount          Decimal             @default(0) @db.Decimal(18, 2)
  totalAmount        Decimal             @default(0) @db.Decimal(18, 2)
  allocatedAmount    Decimal             @default(0) @db.Decimal(18, 2)
  outstandingAmount  Decimal             @default(0) @db.Decimal(18, 2)
  allocationStatus   AllocationStatus    @default(UNALLOCATED)
  journalEntryId     String?             @unique
  journalEntry       JournalEntry?       @relation("SalesInvoiceToJournalEntry", fields: [journalEntryId], references: [id], onDelete: Restrict)
  lines              SalesInvoiceLine[]
  creditNotes        CreditNote[]
  receiptAllocations ReceiptAllocation[]
  postedAt           DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([customerId, status, invoiceDate])
  @@index([allocationStatus])
  @@index([sourceQuotationId])
  @@index([sourceSalesOrderId])
}

model SalesInvoiceLine {
  id                 String       @id @default(cuid())
  salesInvoiceId     String
  salesInvoice       SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  lineNumber         Int
  itemName           String?
  description        String?
  quantity           Decimal      @default(1) @db.Decimal(18, 4)
  unitPrice          Decimal      @db.Decimal(18, 2)
  discountAmount     Decimal      @default(0) @db.Decimal(18, 2)
  taxAmount          Decimal      @default(0) @db.Decimal(18, 2)
  lineSubtotalAmount Decimal      @db.Decimal(18, 2)
  lineAmount         Decimal      @db.Decimal(18, 2)
  revenueAccountId   String
  revenueAccount     Account      @relation("SalesInvoiceRevenueAccount", fields: [revenueAccountId], references: [id], onDelete: Restrict)
  createdAt          DateTime     @default(now())

  @@unique([salesInvoiceId, lineNumber])
  @@index([revenueAccountId])
}

model CreditNote {
  id             String           @id @default(cuid())
  reference      String           @unique
  status         CreditNoteStatus @default(DRAFT)
  noteDate       DateTime
  customerId     String
  customer       Customer         @relation(fields: [customerId], references: [id], onDelete: Restrict)
  salesInvoiceId String?
  salesInvoice   SalesInvoice?    @relation(fields: [salesInvoiceId], references: [id], onDelete: Restrict)
  currencyCode   String           @default("JOD")
  description    String?
  subtotalAmount Decimal          @default(0) @db.Decimal(18, 2)
  discountAmount Decimal          @default(0) @db.Decimal(18, 2)
  taxAmount      Decimal          @default(0) @db.Decimal(18, 2)
  totalAmount    Decimal          @default(0) @db.Decimal(18, 2)
  journalEntryId String?          @unique
  journalEntry   JournalEntry?    @relation("CreditNoteToJournalEntry", fields: [journalEntryId], references: [id], onDelete: Restrict)
  lines          CreditNoteLine[]
  postedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([customerId, status, noteDate])
  @@index([salesInvoiceId])
}

model CreditNoteLine {
  id                 String     @id @default(cuid())
  creditNoteId       String
  creditNote         CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
  lineNumber         Int
  itemName           String?
  description        String?
  quantity           Decimal    @default(1) @db.Decimal(18, 4)
  unitPrice          Decimal    @db.Decimal(18, 2)
  discountAmount     Decimal    @default(0) @db.Decimal(18, 2)
  taxAmount          Decimal    @default(0) @db.Decimal(18, 2)
  lineSubtotalAmount Decimal    @db.Decimal(18, 2)
  lineAmount         Decimal    @db.Decimal(18, 2)
  revenueAccountId   String
  revenueAccount     Account    @relation("CreditNoteRevenueAccount", fields: [revenueAccountId], references: [id], onDelete: Restrict)
  createdAt          DateTime   @default(now())

  @@unique([creditNoteId, lineNumber])
  @@index([revenueAccountId])
}

model ReceiptAllocation {
  id                    String              @id @default(cuid())
  salesInvoiceId        String
  salesInvoice          SalesInvoice        @relation(fields: [salesInvoiceId], references: [id], onDelete: Restrict)
  bankCashTransactionId String
  bankCashTransaction   BankCashTransaction @relation("ReceiptTransactionAllocations", fields: [bankCashTransactionId], references: [id], onDelete: Restrict)
  amount                Decimal             @db.Decimal(18, 2)
  allocatedAt           DateTime            @default(now())
  createdAt             DateTime            @default(now())

  @@unique([salesInvoiceId, bankCashTransactionId])
  @@index([bankCashTransactionId])
}

model JournalEntryLine {
  id             String              @id @default(cuid())
  journalEntryId String
  accountId      String
  lineNumber     Int
  description    String?
  debitAmount    Decimal             @db.Decimal(18, 2)
  creditAmount   Decimal             @db.Decimal(18, 2)
  journalEntry   JournalEntry        @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  account        Account             @relation(fields: [accountId], references: [id], onDelete: Restrict)
  ledgerLines    LedgerTransaction[]
  createdAt      DateTime            @default(now())

  @@unique([journalEntryId, lineNumber])
  @@index([accountId])
}

model PostingBatch {
  id           String              @id @default(cuid())
  postedAt     DateTime            @default(now())
  journalEntry JournalEntry?
  ledgerLines  LedgerTransaction[]
  createdAt    DateTime            @default(now())

  @@index([postedAt])
}

model LedgerTransaction {
  id                 String   @id @default(cuid())
  postingBatchId     String
  journalEntryId     String
  journalEntryLineId String
  accountId          String
  reference          String
  entryDate          DateTime
  postedAt           DateTime
  description        String?
  debitAmount        Decimal  @db.Decimal(18, 2)
  creditAmount       Decimal  @db.Decimal(18, 2)

  fiscalPeriodId String?
  fiscalPeriod   FiscalPeriod? @relation(fields: [fiscalPeriodId], references: [id])

  postingBatch              PostingBatch              @relation(fields: [postingBatchId], references: [id], onDelete: Restrict)
  journalEntry              JournalEntry              @relation(fields: [journalEntryId], references: [id], onDelete: Restrict)
  journalEntryLine          JournalEntryLine          @relation(fields: [journalEntryLineId], references: [id], onDelete: Restrict)
  account                   Account                   @relation(fields: [accountId], references: [id], onDelete: Restrict)
  bankReconciliationMatches BankReconciliationMatch[]

  createdById String?
  createdBy   User?   @relation("LedgerCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([accountId, entryDate, postedAt])
  @@index([journalEntryId])
  @@index([reference])
  @@index([fiscalPeriodId])
}

model FiscalYear {
  id        String         @id @default(cuid())
  year      Int            @unique
  startDate DateTime
  endDate   DateTime
  status    PeriodStatus   @default(OPEN)
  periods   FiscalPeriod[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model FiscalPeriod {
  id           String              @id @default(cuid())
  fiscalYearId String
  fiscalYear   FiscalYear          @relation(fields: [fiscalYearId], references: [id])
  periodNumber Int
  name         String
  startDate    DateTime
  endDate      DateTime
  status       PeriodStatus        @default(OPEN)
  entries      JournalEntry[]
  ledgerLines  LedgerTransaction[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@unique([fiscalYearId, periodNumber])
}

model SegmentDefinition {
  id          String         @id @default(cuid())
  index       Int            @unique // 1 to 5
  name        String // e.g. Department
  description String?
  values      SegmentValue[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model SegmentValue {
  id           String            @id @default(cuid())
  definitionId String
  definition   SegmentDefinition @relation(fields: [definitionId], references: [id])
  code         String
  name         String
  isActive     Boolean           @default(true)

  accountsAsS1 Account[] @relation("Segment1")
  accountsAsS2 Account[] @relation("Segment2")
  accountsAsS3 Account[] @relation("Segment3")
  accountsAsS4 Account[] @relation("Segment4")
  accountsAsS5 Account[] @relation("Segment5")

  // Link users to their primary company (where definition.index = 1)
  users User[] @relation("UserAtCompany")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([definitionId, code])
}

enum UserRole {
  ADMIN // Global SuperAdmin
  MANAGER // Company Root User
  USER // Company Accountant
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  POST
  REVERSE
  OPEN
  CLOSE
  VIEW
}

model AuditLog {
  id       String      @id @default(cuid())
  userId   String?
  user     User?       @relation(fields: [userId], references: [id])
  entity   String // e.g. "Account", "JournalEntry"
  entityId String?
  action   AuditAction
  details  Json?

  // Explicitly scoped to company for fast filtering
  companyId String?

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([companyId])
  @@index([createdAt])
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  password String
  name     String?
  role     UserRole @default(USER)
  isActive Boolean  @default(true)

  // Multi-Tenancy
  companyId String?
  company   SegmentValue? @relation("UserAtCompany", fields: [companyId], references: [id])

  // Hierarchical Management
  parentUserId  String?
  parentUser    User?   @relation("UserHierarchy", fields: [parentUserId], references: [id])
  childrenUsers User[]  @relation("UserHierarchy")

  createdAccounts    Account[]           @relation("AccountCreator")
  updatedAccounts    Account[]           @relation("AccountUpdater")
  createdJournals    JournalEntry[]      @relation("JournalCreator")
  createdLedgerLines LedgerTransaction[] @relation("LedgerCreator")
  auditLogs          AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([companyId])
}
